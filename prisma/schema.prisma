generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  OPERATOR
  VIEWER
}

enum DelayRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ResponseReviewStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum MeasureImportStatus {
  UPLOADED
  PARSED
  IMPORTED
  FAILED
}

enum MeasureImportKind {
  LETTER
  APPENDIX
}

enum MeasureImportSource {
  MANUAL
  EMAIL
}

enum EmailDeliveryStatus {
  PENDING
  SENT
  FAILED
}

enum ContactRole {
  PRIMARY
  RESPONSIBLE
  NOTIFY
}

model Organization {
  id         Int           @id @default(autoincrement()) @map("organization_id")
  name       String        @unique
  shortCode  String?       @map("short_code")
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  subdivisions Subdivision[]
  orders       Order[]
  accessLinks  AccessLink[]
  reportLinks  ReportLink[]
  contacts     ContactPerson[]
  appSettingsHead AppSettings?

  @@map("organizations")
}

model Subdivision {
  id             Int          @id @default(autoincrement())
  organizationId Int          @map("organization_id")
  name           String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orderItems     OrderItem[]
  accessLinks    AccessLink[]
  reportLinks    ReportLink[]
  contacts       ContactPerson[]

  @@unique([organizationId, name])
  @@map("subdivisions")
}

model Status {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  sortOrder  Int         @default(0) @map("sort_order")
  isTerminal Boolean     @default(false) @map("is_terminal")
  orderItems OrderItem[]

  @@map("statuses")
}

model User {
  id                 Int            @id @default(autoincrement()) @map("user_id")
  email              String         @unique
  name               String
  passwordHash       String         @map("password_hash")
  role               UserRole       @default(OPERATOR)
  mustChangePassword Boolean        @default(false) @map("must_change_password")
  locale             String?
  createdAt          DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  measures           Measure[]
  orders             Order[]
  measureImports     MeasureImport[]
  reviewedDelays     DelayRequest[] @relation("DelayReviewer")
  reviewedResponses  Response[]     @relation("ResponseReviewer")

  @@map("users")
}

model Measure {
  id                   Int                @id @default(autoincrement())
  name                 String
  description          String?
  code                 String?
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz()
  createdById          Int                @map("created_by_id")
  sourceImportId       Int?               @map("source_import_id")
  sourceImportItemId   Int?               @unique @map("source_import_item_id")
  createdBy            User               @relation(fields: [createdById], references: [id])
  sourceImport         MeasureImport?     @relation(fields: [sourceImportId], references: [id], onDelete: SetNull)
  sourceImportItem     MeasureImportItem? @relation(fields: [sourceImportItemId], references: [id], onDelete: SetNull)
  orderItems           OrderItem[]

  @@index([name])
  @@index([code])
  @@map("measures")
}

model Order {
  id             Int            @id @default(autoincrement())
  title          String
  organizationId Int            @map("organization_id")
  createdById    Int            @map("created_by_id")
  sourceImportId Int?           @map("source_import_id")
  issuedAt       DateTime       @default(now()) @map("issued_at") @db.Timestamptz()
  defaultDueAt   DateTime?      @map("default_due_at") @db.Timestamptz()
  organization   Organization   @relation(fields: [organizationId], references: [id])
  createdBy      User           @relation(fields: [createdById], references: [id])
  sourceImport   MeasureImport? @relation(fields: [sourceImportId], references: [id], onDelete: SetNull)
  items          OrderItem[]

  @@index([organizationId])
  @@index([sourceImportId])
  @@map("orders")
}

model OrderItem {
  id             Int            @id @default(autoincrement())
  orderId        Int            @map("order_id")
  measureId      Int            @map("measure_id")
  dueAt          DateTime       @map("due_at") @db.Timestamptz()
  statusId       Int            @map("status_id")
  subdivisionId  Int?           @map("subdivision_id")
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  measure        Measure        @relation(fields: [measureId], references: [id])
  status         Status         @relation(fields: [statusId], references: [id])
  subdivision    Subdivision?   @relation(fields: [subdivisionId], references: [id])
  responses      Response[]
  delayRequests  DelayRequest[]
  attachments    ResponseAttachment[]

  @@unique([orderId, measureId])
  @@index([subdivisionId])
  @@map("order_items")
}

model AccessLink {
  id             Int           @id @default(autoincrement())
  token          String        @unique
  organizationId Int           @map("organization_id")
  subdivisionId  Int?          @map("subdivision_id")
  expiresAt      DateTime?     @map("expires_at") @db.Timestamptz()
  revokedAt      DateTime?     @map("revoked_at") @db.Timestamptz()
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subdivision    Subdivision?  @relation(fields: [subdivisionId], references: [id], onDelete: Cascade)

  @@index([organizationId, subdivisionId])
  @@map("access_links")
}

model ReportLink {
  id             Int           @id @default(autoincrement())
  token          String        @unique
  organizationId Int?          @map("organization_id")
  subdivisionId  Int?          @map("subdivision_id")
  revokedAt      DateTime?     @map("revoked_at") @db.Timestamptz()
  expiresAt      DateTime?     @map("expires_at") @db.Timestamptz()
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subdivision    Subdivision?  @relation(fields: [subdivisionId], references: [id], onDelete: Cascade)

  @@index([organizationId, subdivisionId])
  @@map("report_links")
}

model Response {
  id                Int                  @id @default(autoincrement())
  orderItemId       Int                  @map("order_item_id")
  result            String
  commentary        String?
  submittedByLabel  String?              @map("submitted_by_label")
  submittedAt       DateTime             @default(now()) @map("submitted_at") @db.Timestamptz()
  reviewStatus      ResponseReviewStatus @default(PENDING) @map("review_status")
  reviewedById      Int?                 @map("reviewed_by_id")
  reviewedAt        DateTime?            @map("reviewed_at") @db.Timestamptz()
  reviewNote        String?              @map("review_note")
  orderItem         OrderItem            @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  reviewedBy        User?                @relation("ResponseReviewer", fields: [reviewedById], references: [id])
  attachments       ResponseAttachment[]

  @@map("responses")
}

model ResponseAttachment {
  id           Int        @id @default(autoincrement())
  responseId   Int?       @map("response_id")
  orderItemId  Int        @map("order_item_id")
  storageKey   String     @unique @map("storage_key")
  originalName String     @map("original_name")
  mimeType     String     @map("mime_type")
  sizeBytes    Int        @map("size_bytes")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  response     Response?  @relation(fields: [responseId], references: [id], onDelete: Cascade)
  orderItem    OrderItem  @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId, responseId])
  @@map("response_attachments")
}

model DelayRequest {
  id              Int                @id @default(autoincrement())
  orderItemId     Int                @map("order_item_id")
  requestedDueAt  DateTime           @map("requested_due_at") @db.Timestamptz()
  justification   String?
  status          DelayRequestStatus @default(PENDING)
  reviewedById    Int?               @map("reviewed_by_id")
  reviewedAt      DateTime?          @map("reviewed_at") @db.Timestamptz()
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  orderItem       OrderItem          @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  reviewedBy      User?              @relation("DelayReviewer", fields: [reviewedById], references: [id])

  @@map("delay_requests")
}

model AppSettings {
  id                 Int           @id @default(1)
  headOrganizationId Int?          @unique @map("head_organization_id")
  timezone           String        @default("Europe/Moscow")
  locale             String        @default("ru")
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz()
  headOrganization   Organization? @relation(fields: [headOrganizationId], references: [id], onDelete: SetNull)

  @@map("app_settings")
}

model MeasureImport {
  id             Int                 @id @default(autoincrement())
  kind           MeasureImportKind
  status         MeasureImportStatus @default(UPLOADED)
  documentNumber String?             @map("document_number")
  title          String?
  reportDueAt    DateTime?           @map("report_due_at") @db.Timestamptz()
  storageKey     String              @unique @map("storage_key")
  originalName   String              @map("original_name")
  mimeType       String              @map("mime_type")
  sizeBytes      Int                 @map("size_bytes")
  sha256         String?
  parentImportId Int?                @map("parent_import_id")
  uploadedById   Int                 @map("uploaded_by_id")
  importedAt     DateTime?           @map("imported_at") @db.Timestamptz()
  parseError     String?             @map("parse_error")
  uploadedVia    MeasureImportSource @default(MANUAL) @map("uploaded_via")
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime            @updatedAt @map("updated_at") @db.Timestamptz()
  uploadedBy     User                @relation(fields: [uploadedById], references: [id])
  parentImport   MeasureImport?      @relation("ImportAppendix", fields: [parentImportId], references: [id], onDelete: SetNull)
  appendices     MeasureImport[]     @relation("ImportAppendix")
  items          MeasureImportItem[]
  measures       Measure[]
  orders         Order[]

  @@index([status])
  @@index([parentImportId])
  @@map("measure_imports")
}

model MeasureImportItem {
  id          Int            @id @default(autoincrement())
  importId    Int            @map("import_id")
  code        String?
  name        String
  description String?
  sortOrder   Int            @default(0) @map("sort_order")
  included    Boolean        @default(true)
  measureId   Int?           @map("measure_id")
  import      MeasureImport  @relation(fields: [importId], references: [id], onDelete: Cascade)
  measure     Measure?

  @@index([importId])
  @@map("measure_import_items")
}

model EmailDelivery {
  id          Int                 @id @default(autoincrement())
  to          String
  subject     String
  template    String?
  status      EmailDeliveryStatus @default(PENDING)
  error       String?
  relatedType String?             @map("related_type")
  relatedId   Int?                @map("related_id")
  dedupeKey   String?             @unique @map("dedupe_key")
  sentAt      DateTime?           @map("sent_at") @db.Timestamptz()
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz()

  @@index([relatedType, relatedId])
  @@index([status])
  @@map("email_deliveries")
}

model ContactPerson {
  id             Int          @id @default(autoincrement())
  organizationId Int          @map("organization_id")
  subdivisionId  Int?         @map("subdivision_id")
  fullName       String       @map("full_name")
  position       String?
  email          String
  role           ContactRole  @default(RESPONSIBLE)
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subdivision    Subdivision? @relation(fields: [subdivisionId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([subdivisionId])
  @@index([email])
  @@map("contact_persons")
}
