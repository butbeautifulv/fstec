# PostgreSQL (docker-compose)
POSTGRES_USER=fstec
POSTGRES_PASSWORD=fstec
POSTGRES_DB=fstec
POSTGRES_PORT=5433

# Prisma
DATABASE_URL="postgresql://fstec:fstec@localhost:5433/fstec?schema=public"

# Admin session (min 32 chars)
SESSION_SECRET="change-me-to-a-random-string-at-least-32-chars"

# Auth provider: local | active_directory | keycloak
AUTH_PROVIDER=local

# Active Directory stub
AD_LDAP_URL=
AD_BASE_DN=

# Keycloak stub
KEYCLOAK_ISSUER=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REDIRECT_URI=http://localhost:3000/api/auth/keycloak/callback

# Seed admin user
ADMIN_EMAIL=admin@fstec.local
ADMIN_PASSWORD=admin123
