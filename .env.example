# PostgreSQL (docker-compose)
POSTGRES_USER=fstec
POSTGRES_PASSWORD=fstec
POSTGRES_DB=fstec
POSTGRES_PORT=5433

# Prisma
DATABASE_URL="postgresql://fstec:fstec@localhost:5433/fstec?schema=public"

# Redis (optional — dashboard cache; docker compose up redis)
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# Admin session (min 32 chars)
SESSION_SECRET="change-me-to-a-random-string-at-least-32-chars"

# Auth provider: local | active_directory | keycloak
AUTH_PROVIDER=local

# Active Directory stub
AD_LDAP_URL=
AD_BASE_DN=

# Keycloak stub
KEYCLOAK_ISSUER=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REDIRECT_URI=http://localhost:3000/api/auth/keycloak/callback

# Seed admin user
ADMIN_EMAIL=admin@fstec.local
ADMIN_PASSWORD=admin123

# S3-compatible storage (MinIO for local dev)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minioadmin
S3_BUCKET=fstec-attachments
S3_FORCE_PATH_STYLE=true
S3_PORT=9000
S3_CONSOLE_PORT=9001

# App URL (links in email notifications)
APP_URL=http://localhost:3000

# SMTP (Mailpit in docker-compose: localhost:1025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@fstec.local
OPERATOR_NOTIFY_EMAIL=admin@fstec.local

# Cron jobs (due reminders, mail inbox)
CRON_SECRET=change-me-cron-secret

# IMAP inbox for automatic DOCX import (optional)
INBOX_IMAP_HOST=
INBOX_IMAP_PORT=993
INBOX_IMAP_USER=
INBOX_IMAP_PASS=
INBOX_IMAP_SECURE=true
