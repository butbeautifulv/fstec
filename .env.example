# PostgreSQL (docker-compose)
POSTGRES_USER=fstec
POSTGRES_PASSWORD=fstec
POSTGRES_DB=fstec
POSTGRES_PORT=5433

# Prisma
DATABASE_URL="postgresql://fstec:fstec@localhost:5433/fstec?schema=public"

# Admin session (min 32 chars)
SESSION_SECRET="change-me-to-a-random-string-at-least-32-chars"

# Seed admin user
ADMIN_EMAIL=admin@fstec.local
ADMIN_PASSWORD=admin123
