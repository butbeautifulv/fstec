{
  "name": "fstec",
  "version": "0.0.1",
  "type": "module",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:boot": "sh scripts/dev-boot.sh",
    "dev:stack": "sh scripts/dev.sh",
    "dev:infra": "sh scripts/dev-infra.sh",
    "dev:infra:down": "docker compose stop db minio",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "generate:favicons": "node scripts/generate-favicons.mjs",
    "test:unit": "node scripts/test-batch.mjs",
    "test:unit:all": "vitest run --maxWorkers=1 --pool=forks --poolOptions.forks.singleFork=true",
    "test:coverage": "vitest run --coverage --maxWorkers=1 --pool=forks --poolOptions.forks.singleFork=true",
    "test": "npm run test:unit",
    "corpus:audit": "tsx scripts/audit-docx-corpus.mjs",
    "corpus:labels": "node scripts/extract-labels-dataset.mjs",
    "corpus:profiles": "node scripts/build-routing-profiles.mjs",
    "corpus:prepare-slice": "node scripts/prepare-corpus-slice.mjs",
    "corpus:build-seed-manifest": "tsx scripts/build-seed-manifest.mjs",
    "corpus:gap-report": "tsx scripts/corpus-gap-report.mjs",
    "corpus:history": "tsx scripts/extract-corpus-history.mjs",
    "corpus:reconcile-history": "tsx scripts/reconcile-xlsx-history.mjs",
    "corpus:export-errors": "tsx --env-file=.env.local scripts/export-import-errors.mjs",
    "corpus:cleanup-appendices": "tsx --env-file=.env.local scripts/cleanup-junk-appendices.mjs",
    "corpus:validate-parse": "tsx scripts/validate-canonical-parse.mjs",
    "corpus:reparse-imports": "tsx --env-file=.env.local scripts/reparse-imports.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "sh -c '. ./scripts/load-env.sh && prisma migrate dev'",
    "db:push": "sh -c '. ./scripts/load-env.sh && prisma db push'",
    "db:reset": "sh -c '. ./scripts/load-env.sh && prisma migrate reset --force'",
    "db:seed": "tsx --env-file=.env.local prisma/seed.ts",
    "db:seed:corpus": "tsx --env-file=.env.local prisma/seed-corpus.ts",
    "db:seed:corpus:full": "SEED_IMPORT_ALL=1 tsx --env-file=.env.local prisma/seed-corpus.ts",
    "db:boot:corpus": "npm run db:reset && npm run db:seed:corpus",
    "db:seed:mock": "SEED_MOCK=force tsx --env-file=.env.local prisma/seed.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/s3-request-presigner": "^3.1073.0",
    "@prisma/client": "^6.19.3",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "imapflow": "^1.4.2",
    "ioredis": "^5.11.1",
    "iron-session": "^8.0.4",
    "jszip": "^3.10.1",
    "lucide-react": "^1.21.0",
    "motion": "^12.40.0",
    "next": "16.2.6",
    "nodemailer": "^9.0.1",
    "prisma": "^6.19.3",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jszip": "^3.4.0",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^3.2.6"
  }
}
