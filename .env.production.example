# Copy to .env.production and adjust secrets before: sh docker/scripts/prod-scale.sh --build -d

POSTGRES_USER=fstec
POSTGRES_PASSWORD=change-me-strong-postgres-password
POSTGRES_DB=fstec
POSTGRES_REPLICATION_PASSWORD=change-me-strong-replication-password

DATABASE_URL=postgresql://fstec:change-me-strong-postgres-password@db:5432/fstec?schema=public

REDIS_URL=redis://redis:6379

# Redis cache TTL (seconds)
DASHBOARD_CACHE_TTL_SECONDS=300
REFERENCE_CACHE_TTL_SECONDS=900

# Min 32 chars — generate: openssl rand -base64 48
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars-long

AUTH_PROVIDER=local

S3_ACCESS_KEY=fstec-minio
S3_SECRET_KEY=change-me-strong-minio-password
S3_BUCKET=fstec-attachments
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Public HTTPS entrypoint (nginx)
HTTPS_PORT=8443
HTTP_PORT=8080

# Scale tier (powers of 2): 0=1 app single-node | 1=2 | 2=4 | 3=8 + HA data layer
# VM single-node deploy: sh docker/scripts/vm-deploy.sh --build
SCALE_TIER=0

# Baked image tags (podman / vm-deploy)
FSTEC_IMAGE_REGISTRY=localhost/fstec
FSTEC_IMAGE_TAG=latest

# TLS cert CN for nginx self-signed preview (vm-deploy / generate-dev-certs)
VM_DOMAIN=localhost

# Loosen nginx rate limits for load testing (rebuild nginx image)
NGINX_BENCH_MODE=0

# Seed (optional):
#   sh docker/scripts/prod-scale.sh --profile seed-single run --rm seed
#   sh docker/scripts/prod-scale.sh --profile seed-ha run --rm seed-ha
ADMIN_EMAIL=admin@fstec.local
ADMIN_PASSWORD=change-me-admin-password

KEYCLOAK_REDIRECT_URI=https://localhost:8443/api/auth/keycloak/callback

# App URL (links in email notifications)
APP_URL=https://localhost:8443

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@fstec.local
OPERATOR_NOTIFY_EMAIL=

# Cron jobs (due reminders, mail inbox)
CRON_SECRET=change-me-cron-secret

# IMAP inbox for automatic DOCX import (optional)
INBOX_IMAP_HOST=
INBOX_IMAP_PORT=993
INBOX_IMAP_USER=
INBOX_IMAP_PASS=
INBOX_IMAP_SECURE=true
